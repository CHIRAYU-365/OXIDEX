datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              Int      @id @default(autoincrement())
  walletAddress   String   @unique
  onChainId       Int      @unique
  referrerAddress String?
  partnersCount   Int      @default(0)
  totalEarnings   Decimal  @default(0)
  refCode         String?  @unique
  registeredAt    DateTime @default(now())
  lastSeenAt      DateTime @default(now())
}

model AdminConfig {
  id           Int      @id @default(autoincrement())
  level        Int      @unique
  commissionBps Int     
}

model Transaction {
  id             Int      @id @default(autoincrement())
  txHash         String   @unique
  userAddress    String
  eventType      String
  amount         Decimal?
  tokensAmount   Decimal?
  blockNumber    Int
  blockTimestamp DateTime
  rawData        Json?
}

model Earning {
  id            Int      @id @default(autoincrement())
  userAddress   String
  level         Int
  amount        Decimal
  fromAddress   String
  txHash        String
  earnedAt      DateTime @default(now())
}

model Notification {
  id          Int      @id @default(autoincrement())
  userAddress String
  type        String
  title       String
  body        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model PlatformStats {
  id         Int      @id @default(autoincrement())
  totalUsers Int      @default(0)
  totalVolume Decimal  @default(0)
  volume24h  Decimal  @default(0)
  users24h   Int      @default(0)
  updatedAt  DateTime @updatedAt
}
